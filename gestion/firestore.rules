// NOVEX GESTIÓN — Security Rules de Firestore.
// Copia documental: la versión vigente se pega en la consola de
// Firebase (Firestore → Reglas → Publicar).
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function esSocio() {
      return request.auth != null
        && request.auth.uid in [
          'cTh48LC9BIPkE4BK4GeKWCsvnJm1',
          'WWVdEhbOP5e1nIDffNzDGUecIa12'
        ];
    }
    match /{document=**} {
      allow read, write: if esSocio();
    }
  }
}
