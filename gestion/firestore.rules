// NOVEX GESTIÓN — Security Rules de Firestore.
// Copia documental: la versión vigente se pega en la consola de
// Firebase (Firestore → Reglas → Publicar).
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function esSocio() {
      return request.auth != null
        && request.auth.uid in [
          '0H6nIW0JbzUI3igshz4HhLf66le2',
          'NUTgVP6JJAbvJg2ay47GtDgpxrk1'
        ];
    }
    match /{document=**} {
      allow read, write: if esSocio();
    }
  }
}
