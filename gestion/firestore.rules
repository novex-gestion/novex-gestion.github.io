// NOVEX GESTIÓN — Security Rules de Firestore.
// Copia documental: la versión vigente se pega en la consola de
// Firebase (Firestore → Reglas → Publicar).
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function esSocio() {
      return request.auth != null
        && request.auth.uid in [
          '0H6nIW0JbzUI3igshz4HhLf66le2',
          'NUTgVP6JJAbvJg2ay47GtDgpxrk1'
        ];
    }
    // El formulario público de la landing crea consultas (solo crear,
    // solo con esta forma exacta); leer/gestionar queda para los socios.
    match /consultas/{id} {
      allow create: if request.resource.data.keys().hasOnly(
          ['nombre', 'negocio', 'rubro', 'origen', 'estado', 'fecha'])
        && request.resource.data.estado == 'nueva'
        && request.resource.data.origen == 'web'
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() > 0
        && request.resource.data.nombre.size() <= 120
        && request.resource.data.negocio is string
        && request.resource.data.negocio.size() > 0
        && request.resource.data.negocio.size() <= 120
        && request.resource.data.rubro is string
        && request.resource.data.rubro.size() <= 60
        && request.resource.data.fecha is timestamp;
    }
    match /{document=**} {
      allow read, write: if esSocio();
    }
  }
}
