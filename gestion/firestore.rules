// NOVEX GESTIÓN — Security Rules de Firestore.
// Copia documental: la versión vigente se pega en la consola de
// Firebase (Firestore → Reglas → Publicar). Reemplazar UID_IVAN
// y UID_JUAN por los UIDs reales al crear los usuarios.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function esSocio() {
      return request.auth != null
        && request.auth.uid in [
          'UID_IVAN',
          'UID_JUAN'
        ];
    }
    match /{document=**} {
      allow read, write: if esSocio();
    }
  }
}
